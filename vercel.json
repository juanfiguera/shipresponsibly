{
  "buildCommand": "true",
  "outputDirectory": "public",
  "redirects": [
    {
      "source": "/playbook",
      "destination": "/manual",
      "permanent": true
    },
    {
      "source": "/manual",
      "destination": "https://juan.gumroad.com/l/ship-responsibly?utm_source=shipresponsibly&utm_medium=referral&utm_campaign=manual_cta",
      "permanent": false
    },
    {
      "source": "/sample",
      "destination": "https://juan.gumroad.com/l/ship-responsibly-sample?utm_source=shipresponsibly&utm_medium=referral&utm_campaign=sample_chapter",
      "permanent": false
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "X-XSS-Protection", "value": "1; mode=block" }
      ]
    }
  ]
}
