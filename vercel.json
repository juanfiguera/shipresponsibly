{
  "buildCommand": "true",
  "outputDirectory": "public",
  "redirects": [
    {
      "source": "/playbook",
      "destination": "https://juan.gumroad.com/l/ship-responsibly",
      "permanent": false
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "X-XSS-Protection", "value": "1; mode=block" }
      ]
    }
  ]
}
